---
import Layout from '../layouts/Layout.astro';

const twitchUrl = 'https://www.twitch.tv/tehtino';
const youtubeUrl = 'https://www.youtube.com/@tehtino';
---

<Layout title="tehTino – Gamingspaß in Premiumqualität | Twitch & YouTube">
	<!-- Hero -->
	<section class="relative flex flex-1 items-center justify-center overflow-hidden py-24">
		<!-- Hintergrundbild (Dummy) mit Abdunkelung -->
		<div
			class="absolute inset-0 bg-cover bg-center"
			style="background-image: url('/images/hero-bg.svg');"
		>
		</div>
		<div class="absolute inset-0 bg-black/70"></div>

		<div class="relative z-10 mx-auto max-w-3xl px-6 text-center">
			<img
				src="/images/tino.jpg"
				alt="tehTino"
				width="160"
				height="160"
				class="mx-auto mb-8 h-32 w-32 rounded-full border-4 border-purple-400/60 shadow-lg shadow-purple-900/40 sm:h-40 sm:w-40"
			/>
			<h1 class="text-5xl font-extrabold tracking-tight sm:text-7xl">
				teh<span class="text-purple-400">Tino</span>
			</h1>
			<p class="mx-auto mt-6 max-w-xl text-lg text-slate-300 sm:text-xl">
				Jeden Mittwoch und Freitag zum Feierabend – Gamingspaß in Premiumqualität!
			</p>

			<div class="mt-10 flex flex-col items-center justify-center gap-8 sm:flex-row">
				<a
					href={twitchUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-purple-600 px-8 py-4 font-semibold text-white shadow-lg shadow-purple-900/40 transition hover:bg-purple-500 sm:w-auto"
				>
					<svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
						<path d="M4.265 3 3 6.236v13.223h4.502V21.7h2.531l2.278-2.24h3.47L20.7 14.9V3H4.265Zm14.747 11.1-2.7 2.655h-4.319l-2.278 2.24v-2.24H6.096V4.688h12.916V14.1ZM16.115 7.98v4.92h-1.688V7.98h1.688Zm-4.502 0v4.92h-1.688V7.98h1.688Z"/>
					</svg>
					Auf Twitch folgen
				</a>
				<a
					href={youtubeUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-red-600 px-8 py-4 font-semibold text-white shadow-lg shadow-red-900/40 transition hover:bg-red-500 sm:w-auto"
				>
					<svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
						<path d="M23.5 6.2a3.02 3.02 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.52A3.02 3.02 0 0 0 .5 6.2 31.65 31.65 0 0 0 0 12a31.65 31.65 0 0 0 .5 5.8 3.02 3.02 0 0 0 2.123 2.136c1.872.519 9.377.519 9.377.519s7.505 0 9.378-.52A3.02 3.02 0 0 0 23.5 17.8 31.65 31.65 0 0 0 24 12a31.65 31.65 0 0 0-.5-5.8ZM9.545 15.568V8.432L15.818 12l-6.273 3.568Z"/>
					</svg>
					YouTube abonnieren
				</a>
			</div>
		</div>

	</section>

</Layout>
